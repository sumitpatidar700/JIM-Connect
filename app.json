{
  "expo": {
    "name": "JI Connect",
    "slug": "ji-connect",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/jim-logo.png",
    "scheme": "jiconnect",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.patidarsumit.jiconnect",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/jim-logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/jim-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/jim-logo.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#FFFFFF"
          }
        }
      ],
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow JI-Connect to save event images to your photo library.",
          "savePhotosPermission": "Allow JI-Connect to save event images to your photo library."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6fe36c1f-8736-48d9-ad51-7db8d98f6efe"
      }
    }
  }
}
